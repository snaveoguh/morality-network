# Copy to .env.local and replace placeholders before using shared services.
NEXT_PUBLIC_WALLETCONNECT_PROJECT_ID=replace-with-walletconnect-project-id
SESSION_SECRET=replace-with-new-32-byte-session-secret

# Public and server-side RPC overrides
BASE_MAINNET_RPC_URL=https://mainnet.base.org
ETHEREUM_RPC_URL=https://mainnet.rpc.buidlguidl.com
NEXT_PUBLIC_BASE_MAINNET_RPC_URL=https://mainnet.base.org
NEXT_PUBLIC_BASE_RPC_URL=https://mainnet.base.org
NEXT_PUBLIC_BASE_SEPOLIA_RPC_URL=https://sepolia.base.org
NEXT_PUBLIC_MAINNET_RPC_URL=https://mainnet.rpc.buidlguidl.com
NEXT_PUBLIC_ETHEREUM_RPC_URL=https://mainnet.rpc.buidlguidl.com

# Contract addresses
NEXT_PUBLIC_REGISTRY_ADDRESS=0x0000000000000000000000000000000000000000
NEXT_PUBLIC_RATINGS_ADDRESS=0x0000000000000000000000000000000000000000
NEXT_PUBLIC_COMMENTS_ADDRESS=0x0000000000000000000000000000000000000000
NEXT_PUBLIC_TIPPING_ADDRESS=0x0000000000000000000000000000000000000000
NEXT_PUBLIC_LEADERBOARD_ADDRESS=0x0000000000000000000000000000000000000000
NEXT_PUBLIC_PREDICTION_MARKET_ADDRESS=0x0000000000000000000000000000000000000000
NEXT_PUBLIC_POOTER_EDITIONS_ADDRESS=0x0000000000000000000000000000000000000000
NEXT_PUBLIC_AGENT_VAULT_ADDRESS=0x0000000000000000000000000000000000000000

# Durable backend / worker mode
INDEXER_BACKEND_URL=http://localhost:42069
AGENT_RUNTIME_MODE=worker
TRADER_EXECUTION_MODE=worker
INDEXER_WORKER_SECRET=replace-with-shared-worker-write-secret
WORKER_TASKS=scanner,swarm,trader,bridge
WORKER_BRIDGE_CONSUMER_ID=nounirl-bridge
AGENT_BRIDGE_URL=https://noun.wtf
AGENT_BRIDGE_SECRET=replace-with-shared-bridge-secret
AGENT_BRIDGE_PRIVATE_KEY=0xreplace-with-dedicated-bridge-signer-private-key
AGENT_BRIDGE_ALLOWED_SIGNERS=0x0000000000000000000000000000000000000000
AGENT_BRIDGE_REQUIRE_SIGNATURE=true
AGENT_BRIDGE_MAX_SKEW_MS=900000
AGENT_BRIDGE_TOPICS=trade-candidate,research-escalation,emerging-event,contradictions-detected,trade-executed,trade-closed,trader-cycle-complete

# AI providers
ANTHROPIC_API_KEY=replace-with-new-anthropic-api-key
OPENAI_API_KEY=
VENICE_API_KEY=
VENICE_BASE_URL=https://api.venice.ai/api/v1
OLLAMA_ENABLED=false
OLLAMA_BASE_URL=http://127.0.0.1:11434/v1

# AI routing
AI_FAST_PROVIDER_ORDER=ollama,venice,openai,anthropic
AI_PREMIUM_PROVIDER_ORDER=anthropic,openai,venice,ollama
OPENAI_FAST_MODEL=gpt-5-mini
OPENAI_PREMIUM_MODEL=gpt-5
VENICE_FAST_MODEL=qwen3-4b
VENICE_PREMIUM_MODEL=llama-3.3-70b
OLLAMA_FAST_MODEL=qwen2.5:7b-instruct
OLLAMA_PREMIUM_MODEL=qwen2.5:14b-instruct

# AI budgets and pricing (optional; costs default to 0 until you configure rates)
AI_BUDGET_WINDOW_HOURS=24
AI_BUDGET_TOTAL_USD=25
AI_BUDGET_ANTHROPIC_USD=15
AI_BUDGET_OPENAI_USD=10
AI_BUDGET_VENICE_USD=5
AI_BUDGET_OLLAMA_USD=0
AI_PRICE_ANTHROPIC_INPUT_USD_PER_1M=0
AI_PRICE_ANTHROPIC_OUTPUT_USD_PER_1M=0
AI_PRICE_OPENAI_INPUT_USD_PER_1M=0
AI_PRICE_OPENAI_OUTPUT_USD_PER_1M=0
AI_PRICE_VENICE_INPUT_USD_PER_1M=0
AI_PRICE_VENICE_OUTPUT_USD_PER_1M=0
AI_PRICE_OLLAMA_INPUT_USD_PER_1M=0
AI_PRICE_OLLAMA_OUTPUT_USD_PER_1M=0

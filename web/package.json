{
  "name": "web",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "node ./scripts/start.mjs",
    "lint": "eslint",
    "worker:build": "tsc -p tsconfig.worker.json",
    "worker:start": "npm run worker:build && node ./dist-worker/worker/index.js",
    "worker:once": "npm run worker:build && node ./dist-worker/worker/index.js --once",
    "archive:snapshot": "node ./scripts/snapshot-archive.mjs",
    "editorial:generate": "node ./scripts/generate-editorials.mjs",
    "redteam:local": "node ./scripts/red-team-local.mjs",
    "smoke:prod": "bash ./scripts/smoke-check.sh https://pooter.world",
    "smoke:local": "bash ./scripts/smoke-check.sh http://localhost:3000",
    "prepare": "cd .. && git config core.hooksPath .husky || true",
    "typecheck": "tsc --noEmit --pretty",
    "knip": "knip",
    "jscpd": "jscpd src --min-lines 10 --min-tokens 50 --threshold 5",
    "precommit": "npm run typecheck && npm run lint"
  },
  "dependencies": {
    "@a16z/helios": "^0.11.1",
    "@anthropic-ai/sdk": "^0.78.0",
    "@nktkas/hyperliquid": "^0.32.1",
    "@noundry/nouns-assets": "^1.17.0",
    "@nouns/sdk": "^1.2.0",
    "@opensea/seaport-js": "^4.0.7",
    "@prisma/client": "^7.4.0",
    "@rainbow-me/rainbowkit": "^2.2.10",
    "@react-three/drei": "^10.7.7",
    "@react-three/fiber": "^9.5.0",
    "@tanstack/react-query": "^5.90.21",
    "@types/three": "^0.183.1",
    "ethers": "^6.16.0",
    "iron-session": "^8.0.4",
    "lightweight-charts": "^5.1.0",
    "next": "16.1.6",
    "prisma": "^7.4.0",
    "react": "19.2.3",
    "react-dom": "19.2.3",
    "react-markdown": "^10.1.0",
    "rss-parser": "^3.13.0",
    "server-only": "^0.0.1",
    "siwe": "^3.0.0",
    "three": "^0.183.2",
    "viem": "^2.45.3",
    "wagmi": "^3.4.3"
  },
  "devDependencies": {
    "@tailwindcss/postcss": "^4",
    "@types/node": "^20",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "eslint": "^9",
    "eslint-config-next": "16.1.6",
    "husky": "^9.1.7",
    "jscpd": "^4.0.8",
    "knip": "^6.0.4",
    "lint-staged": "^16.4.0",
    "tailwindcss": "^4",
    "typescript": "^5",
    "vitest": "^4.0.18"
  }
}
